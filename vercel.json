{
  "rewrites": [
    { "source": "/en", "destination": "/en/index.html" },
    { "source": "/en/(.*)", "destination": "/en/index.html" },
    { "source": "/us", "destination": "/us/index.html" },
    { "source": "/us/(.*)", "destination": "/us/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
